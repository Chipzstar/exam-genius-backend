{
	"name": "exam-genius-backend",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"start": "nx serve --watch=false",
		"build": "npx prisma generate && nx build",
		"test": "nx test",
		"prisma generate": "npx prisma generate",
		"nx:serve:backend": "nx serve",
		"nx:build:backend": "nx build",
		"nx:build:backend:prod": "npx prisma generate && nx build --prod --skip-nx-cache",
		"nx:serve:backend:prod": "node dist/exam-genius-backend/main.js",
		"create-env-file:backend": "doppler secrets download --no-file --format env > .env -p exam-genius -c loc",
		"create-env-file:backend:prod": "doppler secrets download --no-file --format env > .env.doppler.prod -p exam-genius -c prd"
	},
	"private": true,
	"dependencies": {
		"@fastify/autoload": "~5.7.1",
		"@fastify/cors": "^8.3.0",
		"@fastify/env": "^4.2.0",
		"@fastify/sensible": "~5.2.0",
		"@logtail/node": "^0.5.2",
		"@logtail/winston": "^0.5.2",
		"@prisma/adapter-neon": "^7.2.0",
		"@prisma/client": "7.1.0",
		"axios": "1.9.0",
		"fastify": "~4.19.2",
		"fastify-plugin": "~4.5.0",
		"openai": "^6.15.0",
		"tslib": "^2.3.0",
		"winston": "^3.17.0",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@nx/esbuild": "19.8.9",
		"@nx/eslint": "19.8.9",
		"@nx/eslint-plugin": "19.8.9",
		"@nx/jest": "19.8.9",
		"@nx/js": "19.8.9",
		"@nx/node": "19.8.9",
		"@nx/workspace": "19.8.9",
		"@types/jest": "29.5.14",
		"@types/node": "18.19.99",
		"@typescript-eslint/eslint-plugin": "7.18.0",
		"@typescript-eslint/parser": "7.18.0",
		"esbuild": "^0.19.2",
		"eslint": "8.57.1",
		"eslint-config-prettier": "9.1.2",
		"jest": "29.7.0",
		"jest-environment-node": "^29.4.1",
		"nx": "19.8.9",
		"nx-cloud": "19.1.0",
		"prettier": "^2.6.2",
		"prisma": "7.1.0",
		"ts-jest": "^29.0.5",
		"ts-node": "10.9.1",
		"typescript": "5.5.4"
	}
}