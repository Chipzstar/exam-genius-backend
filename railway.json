{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm nx reset && pnpm run nx:build:backend:prod",
    "buildEnvironment": "V2"
  },
  "deploy": {
    "startCommand": "pnpm run nx:serve:backend:prod",
    "healthcheckPath": "/healthcheck",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
