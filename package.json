{
  "name": "exam-genius-backend",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "start": "nx serve --watch=false",
    "build": "npx prisma generate && nx build",
    "test": "nx test",
    "test:vitest": "nx run exam-genius-backend:test-vitest --skip-nx-cache",
    "test:vitest:watch": "vitest --config vitest.config.ts",
    "prisma generate": "npx prisma generate",
    "nx:serve:backend": "nx serve",
    "nx:build:backend": "nx build",
    "nx:build:backend:prod": "npx prisma generate && nx build --prod --skip-nx-cache",
    "nx:serve:backend:prod": "node dist/exam-genius-backend/main.js",
    "create-env-file:backend": "doppler secrets download --no-file --format env > .env -p exam-genius -c loc",
    "create-env-file:backend:prod": "doppler secrets download --no-file --format env > .env.doppler.prod -p exam-genius -c prd",
    "prisma:merge": "prismerge -i prismerge.json",
    "prisma:sync": "pnpm prisma:merge && npx prisma generate"
  },
  "private": true,
  "dependencies": {
    "@fastify/autoload": "6.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/sensible": "6.0.4",
    "@prisma/client": "7.1.0",
    "axios": "1.16.1",
    "fastify": "5.2.2",
    "fastify-plugin": "5.0.1",
    "openai": "^6.15.0",
    "pdf-parse": "^1.1.1",
    "posthog-node": "^5",
    "tsconfig-paths": "4.2.0",
    "tslib": "^2.3.0",
    "uploadthing": "^7.7.4",
    "winston": "^3.17.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nx/esbuild": "21.6.9",
    "@nx/eslint": "21.6.9",
    "@nx/eslint-plugin": "21.6.9",
    "@nx/jest": "21.6.9",
    "@nx/js": "21.6.9",
    "@nx/node": "21.6.9",
    "@nx/vite": "21.6.9",
    "@nx/web": "21.6.9",
    "@nx/workspace": "21.6.9",
    "@prisma-utils/prismerge": "^1.7.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.15.33",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.9",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "esbuild": "^0.19.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "jest": "30.0.5",
    "jest-environment-node": "^30.4.1",
    "jest-util": "30.0.5",
    "jiti": "2.4.2",
    "nx": "21.6.9",
    "nx-cloud": "19.1.3",
    "prettier": "^2.6.2",
    "prisma": "7.1.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.1",
    "typescript": "5.9.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
